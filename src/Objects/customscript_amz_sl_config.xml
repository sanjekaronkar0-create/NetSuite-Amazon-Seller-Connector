  <name>Amazon - Connector Dashboard</name>
  <notifyadmins>F</notifyadmins>
  <notifyemails></notifyemails>
  <notifyowner>F</notifyowner>
  <notifyuser>F</notifyuser>
  <scriptfile>[/SuiteScripts/AmazonConnector/suitelet/sl_config.js]</scriptfile>
  <scriptdeployments>
    <scriptdeployment scriptid="customdeploy_amz_sl_config">
      <allemployees>T</allemployees>
      <allpartners>F</allpartners>
      <allroles>F</allroles>
      <audslctrole></audslctrole>
      <eventtype></eventtype>
      <isdeployed>T</isdeployed>
      <isonline>F</isonline>
      <loglevel>DEBUG</loglevel>
      <runasrole>ADMINISTRATOR</runasrole>
      <status>RELEASED</status>
      <title>Amazon Connector Dashboard</title>
    </scriptdeployment>
  </scriptdeployments>
</suitelet>