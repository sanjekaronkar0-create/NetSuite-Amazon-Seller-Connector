<customrecordtype scriptid="customrecord_amz_error_queue">
  <recordname>Amazon Error Queue</recordname>
  <includename>F</includename>
  <isinactive>F</isinactive>
  <allowquicksearch>T</allowquicksearch>
  <allowuiaccess>T</allowuiaccess>
  <description>Queue for failed operations with automatic retry and exponential backoff.</description>
  <enablenumbering>T</enablenumbering>
  <numberingprefix>AMZERR-</numberingprefix>
  <enableoptimisticlocking>T</enableoptimisticlocking>
  <enablesystemnotestream>T</enablesystemnotestream>
  <iconbuiltin>T</iconbuiltin>
  <iconindex>14</iconindex>
  <customrecordcustomfields>

    <customrecordcustomfield scriptid="custrecord_amz_eq_type">
      <label>Error Type</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_record_type">
      <label>Record Type</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_record_id">
      <label>Record ID</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_amazon_ref">
      <label>Amazon Reference</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_error_msg">
      <label>Error Message</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_retry_count">
      <label>Retry Count</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_max_retries">
      <label>Max Retries</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_next_retry">
      <label>Next Retry At</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_status">
      <label>Status</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customlist_amz_error_status]</selectrecordtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_payload">
      <label>Retry Payload (JSON)</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_config">
      <label>Configuration</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customrecord_amz_connector_config]</selectrecordtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_eq_created">
      <label>Created</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>READONLY</displaytype>
    </customrecordcustomfield>

  </customrecordcustomfields>
</customrecordtype>
