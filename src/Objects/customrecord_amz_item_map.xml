<customrecordtype scriptid="customrecord_amz_item_map">
  <recordname>Amazon Item Mapping</recordname>
  <includename>F</includename>
  <isinactive>F</isinactive>
  <allowinlinemassupdate>T</allowinlinemassupdate>
  <allowquickadd>F</allowquickadd>
  <allowquicksearch>T</allowquicksearch>
  <allowuiaccess>T</allowuiaccess>
  <description>Maps Amazon ASINs/SKUs to NetSuite inventory items for product cross-reference.</description>
  <enablenumbering>F</enablenumbering>
  <enableoptimisticlocking>T</enableoptimisticlocking>
  <enablesystemnotestream>T</enablesystemnotestream>
  <iconbuiltin>T</iconbuiltin>
  <iconindex>14</iconindex>
  <customrecordcustomfields>

    <customrecordcustomfield scriptid="custrecord_amz_im_asin">
      <label>Amazon ASIN</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon Standard Identification Number</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_seller_sku">
      <label>Amazon Seller SKU</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Seller-assigned SKU on Amazon</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_ns_item">
      <label>NetSuite Item</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-10</selectrecordtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Linked NetSuite inventory item</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_title">
      <label>Amazon Listing Title</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_price">
      <label>Amazon Price</label>
      <fieldtype>CURRENCY</fieldtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_inv_sync">
      <label>Inventory Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_config">
      <label>Configuration</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customrecord_amz_connector_config]</selectrecordtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_last_inv_qty">
      <label>Last Synced Quantity</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>INLINE</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_im_last_synced">
      <label>Last Synced</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
    </customrecordcustomfield>

  </customrecordcustomfields>
</customrecordtype>
