<customrecordtype scriptid="customrecord_amz_connector_config">
  <recordname>Amazon Connector Configuration</recordname>
  <includename>F</includename>
  <isinactive>F</isinactive>
  <allowinlinemassupdate>F</allowinlinemassupdate>
  <allowquickadd>F</allowquickadd>
  <allowquicksearch>F</allowquicksearch>
  <allowuiaccess>T</allowuiaccess>
  <description>Stores Amazon SP-API credentials and connector settings for each Amazon marketplace.</description>
  <enablenumbering>F</enablenumbering>
  <numberingprefix>AMZCFG-</numberingprefix>
  <enableoptimisticlocking>T</enableoptimisticlocking>
  <enablesystemnotestream>T</enablesystemnotestream>
  <iconbuiltin>T</iconbuiltin>
  <iconindex>18</iconindex>
  <customrecordcustomfields>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_marketplace">
      <label>Marketplace</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-104</selectrecordtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon Marketplace (e.g., US, CA, UK, DE)</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_seller_id">
      <label>Amazon Seller ID</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon Seller/Merchant ID</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_client_id">
      <label>SP-API Client ID</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon SP-API LWA Client ID</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_client_secret">
      <label>SP-API Client Secret</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon SP-API LWA Client Secret (encrypted at rest)</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_refresh_token">
      <label>SP-API Refresh Token</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon SP-API LWA Refresh Token (encrypted at rest)</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_endpoint">
      <label>SP-API Endpoint</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon SP-API regional endpoint URL</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_marketplace_id">
      <label>Marketplace ID</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Amazon Marketplace ID (e.g., ATVPDKIKX0DER for US)</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_subsidiary">
      <label>NetSuite Subsidiary</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-117</selectrecordtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>NetSuite subsidiary to associate with this marketplace</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_location">
      <label>Default Warehouse Location</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-103</selectrecordtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Default NetSuite inventory location for this marketplace</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_order_enabled">
      <label>Order Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_inv_enabled">
      <label>Inventory Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_fulfill_enabled">
      <label>Fulfillment Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_settle_enabled">
      <label>Settlement Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_return_enabled">
      <label>Returns Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_last_order_sync">
      <label>Last Order Sync</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
      <description>Timestamp of the last successful order sync</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_last_inv_sync">
      <label>Last Inventory Sync</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
      <description>Timestamp of the last successful inventory sync</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_last_settle_sync">
      <label>Last Settlement Sync</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
      <description>Timestamp of the last successful settlement sync</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_payment_method">
      <label>Payment Method</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-110</selectrecordtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Default payment method for Amazon orders</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_customer">
      <label>Default Amazon Customer</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-2</selectrecordtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
      <description>Generic customer record for Amazon marketplace orders</description>
    </customrecordcustomfield>

    <!-- New Sync Toggles -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_pricing_enabled">
      <label>Pricing Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>F</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_catalog_enabled">
      <label>Catalog Sync Enabled</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>F</defaultvalue>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <!-- Additional Sync Timestamps -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_last_return_sync">
      <label>Last Return Sync</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_last_pricing_sync">
      <label>Last Pricing Sync</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_last_catalog_sync">
      <label>Last Catalog Sync</label>
      <fieldtype>DATETIMETZ</fieldtype>
      <displaytype>INLINE</displaytype>
    </customrecordcustomfield>

    <!-- Order Configuration -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_order_type">
      <label>Order Type</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customlist_amz_order_type]</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Create Sales Orders or Cash Sales from Amazon orders</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_so_form">
      <label>Sales Order Custom Form</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>NORMAL</displaytype>
      <description>Custom form ID to use for Sales Orders</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_cs_form">
      <label>Cash Sale Custom Form</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>NORMAL</displaytype>
      <description>Custom form ID to use for Cash Sales</description>
    </customrecordcustomfield>

    <!-- Financial Accounts for Settlement Reconciliation -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_settle_account">
      <label>Settlement Bank Account</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-112</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Bank account for Amazon settlement deposits</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_fee_account">
      <label>Selling Fee Expense Account</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-112</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Expense account for Amazon selling fees</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_fba_fee_account">
      <label>FBA Fee Expense Account</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-112</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Expense account for FBA fulfillment fees</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_refund_account">
      <label>Refund Account</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-112</selectrecordtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_promo_account">
      <label>Promotional Rebate Account</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-112</selectrecordtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_shipping_item">
      <label>Shipping Charge Item</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-10</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Service/non-inventory item for Amazon shipping charges on orders</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_discount_item">
      <label>Discount Item</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-10</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Discount item for Amazon promotional discounts</description>
    </customrecordcustomfield>

    <!-- FBA Settings -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_fba_enabled">
      <label>Import FBA Orders</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>T</defaultvalue>
      <displaytype>NORMAL</displaytype>
      <description>Import Amazon FBA (Fulfilled by Amazon) orders into NetSuite</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_fba_location">
      <label>FBA Warehouse Location</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-103</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>NetSuite location representing Amazon FBA warehouses</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_fba_customer">
      <label>FBA Customer</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-2</selectrecordtype>
      <displaytype>NORMAL</displaytype>
      <description>Customer record for FBA orders (if different from MFN customer)</description>
    </customrecordcustomfield>

    <!-- Multi-Marketplace -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_addl_mkt_ids">
      <label>Additional Marketplace IDs</label>
      <fieldtype>CLOBTEXT</fieldtype>
      <displaytype>NORMAL</displaytype>
      <description>Comma-separated list of additional marketplace IDs for this region</description>
    </customrecordcustomfield>

    <!-- Automation Flags -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_auto_credit_memo">
      <label>Auto-Create Credit Memos</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>F</defaultvalue>
      <displaytype>NORMAL</displaytype>
      <description>Automatically create Credit Memos when processing Amazon returns</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_auto_deposit">
      <label>Auto-Create Deposits</label>
      <fieldtype>CHECKBOX</fieldtype>
      <defaultvalue>F</defaultvalue>
      <displaytype>NORMAL</displaytype>
      <description>Automatically create Deposit records from settlement data</description>
    </customrecordcustomfield>

    <!-- Tax Handling -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_tax_item">
      <label>Tax Item</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-10</selectrecordtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_tax_code">
      <label>Default Tax Code</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-127</selectrecordtype>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>

    <!-- Error Retry Settings -->

    <customrecordcustomfield scriptid="custrecord_amz_cfg_max_retries">
      <label>Max Retry Attempts</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>NORMAL</displaytype>
      <defaultvalue>3</defaultvalue>
      <description>Maximum number of retry attempts for failed operations</description>
    </customrecordcustomfield>

    <customrecordcustomfield scriptid="custrecord_amz_cfg_retry_delay">
      <label>Retry Delay (Minutes)</label>
      <fieldtype>INTEGER</fieldtype>
      <displaytype>NORMAL</displaytype>
      <defaultvalue>30</defaultvalue>
      <description>Initial delay between retry attempts (doubles each retry)</description>
    </customrecordcustomfield>

  </customrecordcustomfields>
</customrecordtype>
